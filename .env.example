# ==============================================================================
# coffeTide Environment Variables  (참조: doc/as-built-reference.md §6)
# ==============================================================================

# true면 실제 연동/AI 통신 없이 Mock 데이터로 동작
MOCK_MODE=true

# 세션 쿠키 AES-256-GCM 암호화 키 (32바이트 base64)
# 생성(PowerShell): [Convert]::ToBase64String((1..32 | % { [byte](Get-Random -Min 0 -Max 256) }))
# 프로덕션에서 미설정 시 서버가 기동을 거부합니다 (백로그 B1).
SESSION_ENCRYPTION_SECRET=

# Gemini API 키 (분류·브리핑·답장·규칙파싱). 없으면 로컬 FallbackEngine으로 대체.
GEMINI_API_KEY=
# true면 AI 분류를 완전히 끄고 로컬 FallbackEngine만 사용 (킬스위치, 백로그 C1)
DISABLE_AI_CLASSIFY=

# Microsoft Entra ID (Outlook 연동) — doc/0-prerequisites.md 참조
NEXT_PUBLIC_MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
NEXT_PUBLIC_MS_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback

# Google OAuth (Gmail·Calendar·Drive readonly)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Notion 내부 통합 (개발/수동 테스트용 기본값 — UI에서 세션별 입력도 가능)
NOTION_INTEGRATION_TOKEN=
NOTION_DATABASE_ID=

# (선택) LLM 산출물 기본 폴더 경로 (doc/phase6_llm_artifacts_spec.md)
LLM_ARTIFACTS_DEFAULT_PATH=

# 웹 푸시 (아침 브리핑 알림 — 백로그 H5). 생성: npx web-push generate-vapid-keys
# 미설정 시 알림 기능만 비활성화되고 나머지는 정상 동작.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# (선택) 클라우드 배포에서 /api/briefing/daily 를 외부 크론으로 호출할 때의 인증 토큰
CRON_SECRET=
